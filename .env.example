# ============================================================
# HealthGuard Model API — Environment Template
# Copy to .env and fill in values before running the server.
# ============================================================

# ----------------------------------------------------------
# Gemini AI (explanation generation)
# Get key at: https://aistudio.google.com/app/apikey
# ----------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here

# ----------------------------------------------------------
# (Optional) Override default model bundle paths if bundles
# live outside the repo's models/ directory.
# ----------------------------------------------------------
# HEALTHGUARD_HEALTH_BUNDLE_PATH=/abs/path/to/healthguard_bundle.joblib
# HEALTHGUARD_FALL_BUNDLE_PATH=/abs/path/to/fall_bundle.joblib
# HEALTHGUARD_SLEEP_BUNDLE_PATH=/abs/path/to/sleep_score_bundle.joblib

# ----------------------------------------------------------
# (Optional) Risk thresholds — override defaults.
# ----------------------------------------------------------
# HEALTHGUARD_HEALTH_THRESHOLDS__HIGH_RISK_TRUE_AT=0.5
# HEALTHGUARD_FALL_THRESHOLDS__FALL_TRUE_AT=0.5
